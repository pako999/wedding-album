# ── Clerk Auth ────────────────────────────────────────────────────────────────
# Get from https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...

# Clerk redirect URLs (copy these exactly)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ── Database (Neon PostgreSQL) ─────────────────────────────────────────────────
# Get from https://console.neon.tech
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# ── Vercel Blob ────────────────────────────────────────────────────────────────
# Get from Vercel project → Storage → Blob
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# ── Email (Resend) ─────────────────────────────────────────────────────────────
# Get from https://resend.com/api-keys
RESEND_API_KEY=re_...
RESEND_FROM=album@wedflow.app

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://photos.wedflow.app

# ── Internal API key (WedFlow → Album integration) ───────────────────────────
WEDFLOW_API_KEY=your-secret-key-here

# ── Paddle (payments) ─────────────────────────────────────────────────────────
# "sandbox" or "live". Sandbox uses sandbox-api.paddle.com + sandbox Paddle.js.
PADDLE_ENV=sandbox
NEXT_PUBLIC_PADDLE_ENV=sandbox
# Server API key — Paddle dashboard → Developer Tools → Authentication
PADDLE_API_KEY=pdl_sdbx_apikey_...
# Client-side token for Paddle.js — same screen, "Client-side tokens"
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=test_...
# Webhook signing secret — Paddle dashboard → Notifications → your destination
PADDLE_WEBHOOK_SECRET=pdl_ntfset_...
